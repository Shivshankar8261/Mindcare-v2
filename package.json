{
  "name": "mindcare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pkill -f \"next dev.*3002\" 2>/dev/null || true; lsof -ti:3002 | xargs kill -9 2>/dev/null || true",
    "dev": "rm -rf .next node_modules/.cache && prisma generate && next dev -p 3002",
    "dev:clean": "lsof -ti:3002 | xargs kill -9 2>/dev/null || true && rm -rf .next node_modules/.cache src/generated/prisma && prisma generate && next dev -p 3002",
    "prebuild": "rm -rf .next node_modules/.cache",
    "build": "prisma generate && next build",
    "start": "next start -p 3002",
    "start:stable": "rm -rf .next && prisma generate && next build && next start -p 3002",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google-cloud/translate": "^9.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "openai": "^6.33.0",
    "prisma": "^7.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
